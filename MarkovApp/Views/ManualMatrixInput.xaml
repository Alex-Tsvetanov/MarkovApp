<Window x:Class="MarkovApp.Views.ManualMatrixInput"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manual Matrix Input"
        Height="450" Width="600"
        MinHeight="400" MinWidth="500"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ControlBackgroundBrush}"
                BorderBrush="{StaticResource AccentBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="4"
                Margin="0,0,0,8">
            <DockPanel>
                <TextBlock Text="Transition Matrix"
                           DockPanel.Dock="Top"
                           Margin="0,0,0,5"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              MaxHeight="350">
                    <ItemsControl ItemsSource="{Binding TransitionMatrix}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding Size}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Width="50"
                                         Height="50"
                                         Margin="0"
                                         Padding="0"
                                         Background="#222222"
                                         Foreground="LightGreen"
                                         FontWeight="Bold"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.ToolTip>
                                        <ToolTip Background="{StaticResource ControlBackgroundBrush}"
                                                 Foreground="LightGreen"
                                                 Padding="4">
                                            <TextBlock Text="{Binding TooltipText, Mode=OneWay}"/>
                                        </ToolTip>
                                    </TextBox.ToolTip>
                                </TextBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource ControlBackgroundBrush}"
                BorderBrush="{StaticResource AccentBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="4"
                Margin="0,8,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Initial State Vector:"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"/>

                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding InitialStateVector}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBox Width="50"
                                         Height="50"
                                         Margin="0"
                                         Padding="0"
                                         Background="#222222"
                                         Foreground="LightGreen"
                                         FontWeight="Bold"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.ToolTip>
                                        <ToolTip Background="{StaticResource ControlBackgroundBrush}"
                                                 Foreground="LightGreen"
                                                 Padding="4">
                                            <TextBlock Text="{Binding Index, StringFormat='State: {0}', Mode=OneWay}"/>
                                        </ToolTip>
                                    </TextBox.ToolTip>
                                </TextBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Increment Size"
                    Width="120"
                    Command="{Binding IncrementSizeCommand}"
                    Margin="0,0,10,0"/>
            <Button Content="Submit"
                    Width="80"
                    Command="{Binding SubmitCommand}"/>
        </StackPanel>

    </Grid>
</Window>