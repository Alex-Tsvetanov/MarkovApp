<Window x:Class="MarkovApp.Views.RegularMatrixResultDisplay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Regular Markov Chain Results"
        Height="500" Width="800"
        MinHeight="400" MinWidth="700"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Border Padding="15" 
            Background="{StaticResource ControlBackgroundBrush}" 
            BorderBrush="{StaticResource AccentBorderBrush}" 
            BorderThickness="2" 
            CornerRadius="8"
            Margin="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Result matrix:" 
                       Grid.Row="0" Grid.Column="0"
                       Style="{StaticResource ResultHeaderStyle}"
                       Margin="0,0,10,5"/>

            <TextBlock Text="Limiting probabilities:" 
                       Grid.Row="2" Grid.Column="0"
                       Style="{StaticResource ResultHeaderStyle}"
                       Margin="0,10,10,5"/>

            <TextBlock Text="s.P^n:" 
                       Grid.Row="2" Grid.Column="1"
                       Style="{StaticResource ResultHeaderStyle}"
                       Margin="10,10,0,5"/>

            <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{StaticResource ControlBackgroundBrush}">
                <TextBox Text="{Binding MatrixText, Mode=OneWay}"
                         Style="{StaticResource ResultTextBoxStyle}"/>
            </ScrollViewer>

            <ScrollViewer Grid.Row="3" Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{StaticResource ControlBackgroundBrush}">
                <TextBox Text="{Binding LimitingProbabilitiesText, Mode=OneWay}"
                         Style="{StaticResource ResultTextBoxStyle}"/>
            </ScrollViewer>

            <ScrollViewer Grid.Row="3" Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{StaticResource ControlBackgroundBrush}">
                <TextBox Text="{Binding ResultVectorText, Mode=OneWay}"
                         Style="{StaticResource ResultTextBoxStyle}"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>